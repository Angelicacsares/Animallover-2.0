// ======================================================
// CAMPO DE BUSCA
// ======================================================

function campoBusca(placeholder = "Buscar"){

    return `

        <div class="buscar">

            <span class="lupa">🔍</span>

            <input
                type="text"
                placeholder="${placeholder}"
            >

        </div>

    `;

}



// ======================================================
// CAMPO DE TEXTO
// ======================================================

function campoTexto(
    label,
    id,
    placeholder,
    atributos = ""
){

    return `

        <div class="campo">

            <label>${label}</label>

            <input
                type="text"
                id="${id}"
                placeholder="${placeholder}"
                ${atributos}
            >

        </div>

    `;

}



// ======================================================
// CAMPO DATA
// ======================================================

function campoData(label, id){

    return `

        <div class="campo">

            <label>${label}</label>

            <input
                type="date"
                id="${id}"
            >

        </div>

    `;

}



// ======================================================
// CAMPO SELECT
// ======================================================

function campoSelect(label, id, opcoes){

    let html = `

        <div class="campo">

            <label>${label}</label>

            <select id="${id}">

    `;

    opcoes.forEach(function(opcao){

        html += `

            <option value="${opcao}">
                ${opcao}
            </option>

        `;

    });

    html += `

            </select>

        </div>

    `;

    return html;

}



// ======================================================
// CAMPO TEXTO GRANDE
// ======================================================

function campoTextarea(label, id, placeholder){

    return `

        <div class="campo">

            <label>${label}</label>

            <textarea
                id="${id}"
                placeholder="${placeholder}"
                rows="4"
            ></textarea>

        </div>

    `;

}



// ======================================================
// FOTO DO PET
// ======================================================

function campoImagem(){

    return `

        <div class="foto-pet">

            <label
                for="fotoPet"
                class="circulo-foto"
            >

                📷

                <span>Enviar imagem</span>

            </label>

            <input
                type="file"
                id="fotoPet"
                accept="image/*"
                hidden
            >

            <p>Foto do Pet</p>

        </div>

    `;

}



// ======================================================
// CARD DO TUTOR
// ======================================================

function cardTutorPet(tutor){

    let iniciais = tutor.nome
        .split(" ")
        .map(nome => nome[0])
        .slice(0,2)
        .join("");

    return `

        <div class="cliente">

            <div class="avatar">

                ${iniciais}

            </div>

            <div class="dados-cliente">

                <h3>${tutor.nome}</h3>

                <p>Tutor selecionado</p>

            </div>

        </div>

    `;

}



// ======================================================
// RODAPÉ NOVO PET
// ======================================================

function rodapeNovoPet(id){

    return `

        <div class="rodape-formulario">

            <button
                class="botao"
                onclick="salvarPet(${id})"
            >

                Salvar

            </button>

            <button
                class="botao"
                onclick="salvarEAgendar(${id})"
            >

                Salvar e Agendar

            </button>

        </div>

    `;

}



