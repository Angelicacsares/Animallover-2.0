// ======================================================
// CARD DE CLIENTE
// ======================================================

function cardCliente(id, nome, telefone){

    let iniciais = nome
        .split(" ")
        .map(p => p[0])
        .slice(0,2)
        .join("");

    return `

        <div
            class="cliente"
            onclick="abrirFichaCliente(${id})"
        >

            <div class="avatar">

                ${iniciais}

            </div>

            <div class="dados-cliente">

                <h3>${nome}</h3>

                <p>${telefone}</p>

            </div>

            <div
                class="menu-cliente"
                onclick="event.stopPropagation()"
            >

                ⋮

            </div>

        </div>

    `;

}



// ======================================================
// CARD SELECIONAR TUTOR
// ======================================================

function cardSelecionarTutor(id, nome){

    let iniciais = nome
        .split(" ")
        .map(p => p[0])
        .slice(0,2)
        .join("");

    return `

        <div
            class="cliente"
            onclick="abrirNovoPet(${id})"
        >

            <div class="avatar">

                ${iniciais}

            </div>

            <div class="dados-cliente">

                <h3>${nome}</h3>

            </div>

        </div>

    `;

}



